import socket
import subprocess
import struct
import sys

def initialize_adapter(interface_name):
    """
    Quest 1: Wakes the unmanaged adapter, shifts it to monitor mode,
    and locks power saving to OFF.
    """
    print(f"[*] Initializing hardware: {interface_name}")
    try:
        # 1. Take link down to change operational states safely
        subprocess.run(["sudo", "ip", "link", "set", interface_name, "down"], check=True)
        
        # 2. Shift the physical radio into Monitor Mode
        subprocess.run(["sudo", "iw", interface_name, "set", "type", "monitor"], check=True)
        
        # 3. Bring the link back up online
        subprocess.run(["sudo", "ip", "link", "set", interface_name, "up"], check=True)
        
        # 4. CRITICAL: Kill power save so the unmanaged hardware never sleeps
        subprocess.run(["sudo", "iw", "dev", interface_name, "set", "power_save", "off"], check=True)
        
        print(f"[+] {interface_name} is awake and locked in Monitor Mode!")
        
    except subprocess.CalledProcessError as e:
        print(f"[-] Hardware Init Failed: {e}")
        print("[!] Make sure to run your script with: sudo python3 script.py")
        sys.exit(1)


def parse_beacon(packet):
    """
    Surgically extracts the BSSID and SSID from a raw 802.11 frame.
    Note: Real wireless cards append a 'Radiotap Header' to the front 
    of raw frames detailing signal strength (usually 18 to 36 bytes long).
    """
    try:
        # 1. Skip the variable Radiotap header to find the 802.11 Core Frame
        # We look for the length of the radiotap header at byte index 2
        rt_len = packet[2]
        wlan_frame = packet[rt_len:]
        
        # 2. Check the Frame Control field (First byte)
        # Type: Management (0x00), Subtype: Beacon (0x08) -> 0x80 or 0x08 depending on endianness
        frame_type = wlan_frame[0]
        if frame_type != 0x80: 
            return None  # Drop packet if it's not a Beacon frame
        
        # 3. Extract the BSSID (MAC Address of the Router) located at bytes 16-21
        bssid_bytes = wlan_frame[16:22]
        bssid = ":".join(f"{b:02x}" for b in bssid_bytes)
        
        # 4. Jump past the Fixed Parameters (12 bytes starting at byte 24) to reach Wireless Tags
        tags_start = 36
        
        # 5. Tag 0 is always the SSID (Network Name)
        tag_number = wlan_frame[tags_start]
        tag_length = wlan_frame[tags_start + 1]
        
        if tag_number == 0 and tag_length > 0:
            ssid = wlan_frame[tags_start + 2 : tags_start + 2 + tag_length].decode('utf-8', errors='ignore')
        else:
            ssid = "<Hidden SSID>"
            
        return bssid, ssid
    except Exception:
        return None

def start_continuous_scan(interface):
    print(f"[*] Opening raw socket on {interface}...")
    
    try:
        """
        socket.AF_PACKET: This is a low-level Linux-specific interface. It tells the operating system,
            "I do not want internet data (Layer 3/4).
            I want raw Link Layer packets (Layer 2) straight off the hardware network card."
        
        socket.SOCK_RAW: This tells Python not to strip away the headers. We want the raw packet format,
            including the MAC addresses and Wi-Fi management data.
        
        socket.htons(0x0003): 0x0003 is the Linux constant for ETH_P_ALL. 
            It tells the network card to capture every single packet it hears, regardless of the protocol type. 
            htons() ensures the number is formatted correctly for network memory (Big-Endian).
        
        """
        raw_socket = socket.socket(socket.AF_PACKET, socket.SOCK_RAW, socket.htons(0x0003))
        
        # Bind the raw socket directly to your monitor interface, only listening through the usb adapter
        raw_socket.bind((interface, 0x0003))
        """
            :<20 means: "Reserve exactly 20 character spaces for this column, and left-align the text."
            "-" * 50 create line seperator
        """
        print(f"? Scanner Active. Listening for beacons on {interface} infinitely...\n")
        print(f"{'BSSID (MAC Address)':<20} | {'SSID (Network Name)'}")
        print("-" * 50)
        
        # set for discovered networks
        discovered_aps = set()
        
        # The Continuous Scan Loop
        while True:
            """
                recvfrom(2048): This is a "blocking" function. The script stops here and waits. 
                The moment your Wi-Fi card detects a packet floating through the air, it grabs it,
                pulls up to 2048 bytes of data, and passes it into the packet variable as a raw string of bytes (zeros and ones).
            """
            packet, _ = raw_socket.recvfrom(2048)
            
            result = parse_beacon(packet)
            if result:
                bssid, ssid = result
                if bssid not in discovered_aps:
                    discovered_aps.add(bssid)
                    print(f"{bssid:<20} | {ssid}")
                    
    except PermissionError:
        print("? Error: You MUST run this script with root privileges (sudo) to open raw sockets.")
    except KeyboardInterrupt:
        print("\n[!] Scanning stopped by user.")
    except Exception as e:
        print(f"? Critical Error: {e}")

